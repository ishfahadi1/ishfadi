    { "name": "Waiting List",    "short_name": "Waitlist",  "description": "Join the waiting list",     "url": "/index.html?shortcut=waitlist",  "icons": [{ "src": "icons/sc-wait.png",      "sizes": "96x96", "type": "image/png" }] }
